    "version": "0.2.0",
    "configurations": [
        

        {
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/third_party/BLIP"
            },
            "name": "Python Debugger: Evaluate CrossOver",
            "type": "debugpy",
            "request": "launch",
            "module": "mmfe_evaluation.evaluate_crossover",
            "console": "integratedTerminal",    
            "args": [
                "--ckpt", "/home/xavi/CrossOver/checkpoints/",
                "--data_root", "/home/xavi/mmfe/data/structure3D/Structured3D_bbox/Structured3D",
                "--val_json", "/home/xavi/mmfe/data/structure3D/val.json",
                "--all_pairs",
                "--furniture_pct", "0.0", "0.5", "1.0",
            ]
        },

        {
            "env": {
                "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/third_party/BLIP",
                "PYTHONWARNINGS": "ignore"
            },
            "name": "Python Debugger: Evaluate Scene Retrieval",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_evaluation.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--config-path", "${workspaceFolder}/configs/evaluation",
                "--config-name", "eval_scene.yaml",
                "task.InferenceSceneRetrieval.val=['Scannet']",
                "task.InferenceSceneRetrieval.ckpt_path=/home/xavi/CrossOver/checkpoints/mmfe_global_desc/51611590/best.ckpt",
                // "task.InferenceSceneRetrieval.ckpt_path=/home/xavi/CrossOver/checkpoints/model.safetensors",
                "hydra.run.dir=.",
                "hydra.output_subdir=null"
            ]
        },
    ]
}